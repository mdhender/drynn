# /etc/drynn/drynn.env — Environment overrides for the drynn systemd service.
#
# This file is loaded by the systemd unit via EnvironmentFile=.
# Values here override the config file (server.json).
# Uncomment and set only the variables you need to override.
#
# DATABASE_URL=postgres://drynn_prod_user:PASSWORD@HOST:25060/drynn_prod?sslmode=verify-full&sslrootcert=/etc/drynn/pki/managed-pg-ca.crt
# APP_ADDR=127.0.0.1:8080
# COOKIE_SECURE=true
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=168h
# MAILGUN_API_KEY=
# MAILGUN_SENDING_DOMAIN=
# MAILGUN_FROM_ADDRESS=
# MAILGUN_FROM_NAME=
# REQUEST_ACCESS_ENABLED=false
# ADMIN_CONTACT_EMAIL=
